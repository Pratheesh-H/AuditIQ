{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "devCommand": "",
  "outputDirectory": ".",
  "installCommand": "",
  "functions": {
    "api/gemini.js": { "memory": 512, "maxDuration": 30 },
    "api/groq.js":   { "memory": 256, "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/gemini", "dest": "/api/gemini.js" },
    { "src": "/api/groq",   "dest": "/api/groq.js" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
