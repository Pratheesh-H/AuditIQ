{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "devCommand": null,
  "outputDirectory": null,
  "installCommand": null,
  "functions": {
    "api/gemini.js": { "maxDuration": 30 },
    "api/groq.js":   { "maxDuration": 30 }
  },
  "routes": [
